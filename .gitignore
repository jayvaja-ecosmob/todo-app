# ------------------------------
# OS files
# ------------------------------
.DS_Store
Thumbs.db
.history/

# ------------------------------
# Node.js (Frontend + Backend)
# ------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Package locks (optional - usually keep them)
# package-lock.json

# ------------------------------
# Environment variables (IMPORTANT)
# ------------------------------
.env
.env.*
backend/.env
frontend/.env

# Example env should be tracked
!*.env.example

# ------------------------------
# Build outputs
# ------------------------------
dist/
build/
frontend/dist/
backend/dist/

# ------------------------------
# Logs
# ------------------------------
logs/
*.log

# ------------------------------
# Docker
# ------------------------------
*.pid
*.seed
*.pid.lock

# Docker overrides (optional)
docker-compose.override.yml

# ------------------------------
# IDE / Editor
# ------------------------------
.vscode/
.idea/
*.swp
*.swo

# ------------------------------
# Cache / temp
# ------------------------------
.cache/
.tmp/
temp/

# ------------------------------
# Coverage / testing
# ------------------------------
coverage/

